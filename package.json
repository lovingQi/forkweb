{
  "name": "forkweb",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "vue-tsc -b",
    "preview": "vite preview",
    "replay:dev": "tsx replay-server/src/index.ts",
    "replay:dev:all": "node scripts/start-replay-dev.mjs",
    "replay:build": "tsc -p replay-server/tsconfig.json",
    "replay:start": "node replay-server/dist/index.js",
    "replay:verify:assistant": "tsx replay-server/scripts/verify-assistant.ts",
    "replay:verify:knowledge": "tsx replay-server/scripts/verify-knowledge.ts",
    "replay:audit:knowledge": "tsx replay-server/scripts/audit-knowledge.ts",
    "replay:verify:samples": "tsx replay-server/scripts/verify-samples.ts",
    "replay:collect": "node scripts/collect-replay-case.mjs",
    "test:e2e:replay": "npx -y -p node@20 -c 'playwright test tests/e2e/replay.spec.ts'",
    "test:e2e:replay:headed": "npx -y -p node@20 -c 'playwright test tests/e2e/replay.spec.ts --headed'",
    "test:e2e:tickets": "npx -y -p node@20 -c 'playwright test tests/e2e/tickets.spec.ts'",
    "test:e2e:tickets:headed": "npx -y -p node@20 -c 'playwright test tests/e2e/tickets.spec.ts --headed'"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "archiver": "^8.0.0",
    "axios": "^1.7.2",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^9.6.0",
    "cors": "^2.8.6",
    "element-plus": "^2.7.6",
    "express": "^4.22.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.3",
    "pinia": "^2.1.7",
    "tar": "^6.2.1",
    "unzipper": "^0.12.5",
    "uuid": "^14.0.1",
    "vue": "^3.4.31",
    "vue-router": "^4.4.0",
    "ws": "^8.21.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/archiver": "^8.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.2.0",
    "@types/node": "^20.14.9",
    "@types/nodemailer": "^8.0.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^5.0.5",
    "node-gyp": "^8.4.1",
    "tsx": "^3.14.0",
    "typescript": "^5.4.5",
    "vite": "^5.3.2",
    "vue-tsc": "^2.0.24"
  }
}
